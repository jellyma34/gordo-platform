# Скопируйте в переменные окружения Railway (или .env.production для ветки staging).
# Важно: здесь URL бэкенда FastAPI для staging, не домен фронтенда.
NEXT_PUBLIC_API_URL=https://<staging-backend>.up.railway.app
NEXT_PUBLIC_APP_ENV=staging

# Лог в консоли браузера: URL запроса и факт наличия токена (см. lib/auth.ts)
# NEXT_PUBLIC_DEBUG_API=1
