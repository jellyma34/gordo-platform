# Базовый URL бэкенда (FastAPI). Подставляется в браузер как NEXT_PUBLIC_* .
# Скопируйте в `.env.local` (файл в .gitignore). Для локальной разработки можно указать dev backend:
NEXT_PUBLIC_API_URL=https://gordo-platform-dev.up.railway.app
NEXT_PUBLIC_APP_ENV=development

# Staging / production: в Railway задайте URL бэкенда для этой среды (не подставляйте dev URL).
# См. `.env.staging.example` и `.env.production`.

# Отладка запросов к API (URL + наличие токена в консоли):
# NEXT_PUBLIC_DEBUG_API=1

# Production-сборка: см. `.env.production` — `NEXT_PUBLIC_API_URL=https://gordo-platform-production.up.railway.app`
# `next dev`: при production URL в `.env.local` next.config.js подменяет на dev (см. enforceDevelopmentApiUrl).
# Чтобы при `next dev` ходить в локальный FastAPI:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
# NEXT_PUBLIC_API_FORCE_LOCAL=1

# Другой публичный URL (ngrok, другой хостинг):
# NEXT_PUBLIC_API_URL=https://xxxx.example.com
