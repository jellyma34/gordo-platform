# Базовый URL бэкенда без суффикса /api (иначе возможен двойной /api/api в URL).
# Запросы: {NEXT_PUBLIC_API_URL}{NEXT_PUBLIC_API_PREFIX}/… (по умолчанию префикс /api).
#
# Локальная разработка (рекомендуется скопировать в .env.local или опереться на .env.development):
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Railway / staging / production — задайте в окружении деплоя или закомментируйте блок выше и используйте:
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# NEXT_PUBLIC_API_PREFIX=/api
# Только для старого бэкенда без префикса /api: NEXT_PUBLIC_API_PREFIX=
NEXT_PUBLIC_APP_ENV=development
