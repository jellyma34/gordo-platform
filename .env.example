# Скопируйте в `.env.local` (перекрывает `.env.development`).
# Локально: тот же порт, что у uvicorn (часто 8000), например:
# NEXT_PUBLIC_API_URL=http://localhost:8000
# Удалённо: абсолютный URL FastAPI без завершающего /api.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development

# Ключ проекта для общего графика платежей (файлы в data/marketing-payment-plan/). Совпадает с query/сервером.
# NEXT_PUBLIC_MARKETING_PAYMENT_PLAN_PROJECT_ID=default

# NEXT_PUBLIC_DEBUG_API=1

# Строительство (ГПР, ТМЦ): local = Next API / localStorage / mock; postgres = FastAPI + PostgreSQL (по умолчанию).
# NEXT_PUBLIC_CONSTRUCTION_STORAGE=local
# NEXT_PUBLIC_GPR_STORAGE=local
# NEXT_PUBLIC_GPR_PROJECT_ID=default

# Production-сборка: см. `.env.production`.
