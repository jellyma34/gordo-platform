# Скопируйте в `.env.local` (перекрывает `.env.development`).
# Локально: тот же порт, что у uvicorn (часто 8000), например:
# NEXT_PUBLIC_API_URL=http://localhost:8000
# Удалённо: абсолютный URL FastAPI без завершающего /api.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development

# NEXT_PUBLIC_DEBUG_API=1

# Production-сборка: см. `.env.production`.
