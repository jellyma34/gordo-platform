# Базовый URL бэкенда без суффикса /api (иначе возможен двойной /api/api в URL).
# Запросы идут на {NEXT_PUBLIC_API_URL}{NEXT_PUBLIC_API_PREFIX}/… (по умолчанию префикс /api).
NEXT_PUBLIC_API_URL=https://gordo-platform-dev.up.railway.app
# Не задавайте или оставьте по умолчанию — совпадает с backend (main.py API_PREFIX=/api).
# NEXT_PUBLIC_API_PREFIX=/api
# Только для старого бэкенда без префикса /api: NEXT_PUBLIC_API_PREFIX=
NEXT_PUBLIC_APP_ENV=development

# Staging: см. `.env.staging.example`. Production: см. `.env.production`.
# Production-сборка: `NEXT_PUBLIC_API_URL=https://gordo-platform-production.up.railway.app`
# Чтобы при `next dev` ходить в локальный FastAPI:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
# NEXT_PUBLIC_API_FORCE_LOCAL=1

# Другой публичный URL (ngrok, другой хостинг):
# NEXT_PUBLIC_API_URL=https://xxxx.example.com
