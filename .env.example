# Базовый URL бэкенда (FastAPI). Подставляется в браузер как NEXT_PUBLIC_* .
# Скопируйте в `.env.local` (не коммитьте). Для `next dev` без файла — переменная не задана.
# Локально — если Next и API на одной машине (порт по умолчанию в backend/run.py — 8080):
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Продакшен Railway: без порта во внешнем URL (не :8000 и не :$PORT):
# NEXT_PUBLIC_API_URL=https://gordo-platform-production.up.railway.app

# Доступ с другого устройства, ngrok, Vercel и т.д. — публичный URL API (не localhost):
# NEXT_PUBLIC_API_URL=https://xxxx.ngrok-free.app
