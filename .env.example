# Базовый URL бэкенда (FastAPI). Подставляется в браузер как NEXT_PUBLIC_* .
# Скопируйте в `.env.local` (не коммитьте). Для `next dev` без файла — переменная не задана.
# Локально — если Next и API на одной машине:
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Доступ с другого устройства, ngrok, Railway, Vercel и т.д. — публичный URL API (не localhost):
# NEXT_PUBLIC_API_URL=https://xxxx.ngrok-free.app
# NEXT_PUBLIC_API_URL=https://your-api.railway.app
