# Базовый URL бэкенда (FastAPI). Подставляется в браузер как NEXT_PUBLIC_* .
# Скопируйте в `.env.local` (файл в .gitignore). В продакшене — без порта в домене Railway.
NEXT_PUBLIC_API_URL=https://gordo-platform-production.up.railway.app
NEXT_PUBLIC_APP_ENV=development

# Локально (Next и API на одной машине, порт API по умолчанию 8080):
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Другой публичный URL (ngrok, другой хостинг):
# NEXT_PUBLIC_API_URL=https://xxxx.example.com
