APP_ENV=dev
# Если не задано или пусто — в коде подставляется sqlite:///./dev.db (см. app/config.py).
# На проде задайте PostgreSQL, например: DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///./gordo.db
CORS_ORIGINS=*
SECRET_KEY=dev-insecure-change-me

# Bootstrap admin: creates user only if missing.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_SYNC_ON_START=false

# Only for local troubleshooting.
LOGIN_DEBUG=false
