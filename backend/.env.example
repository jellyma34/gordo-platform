APP_ENV=dev
DATABASE_URL=sqlite:///./gordo.db
CORS_ORIGINS=*
SECRET_KEY=dev-insecure-change-me

# Bootstrap admin: creates user only if missing.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me
BOOTSTRAP_ADMIN_SYNC_ON_START=false

# Only for local troubleshooting.
LOGIN_DEBUG=false
