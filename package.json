{
  "name": "gordo-gpr",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev -p 3000",
    "clean:next": "node ./scripts/clean-next.mjs",
    "dev:clean": "node ./scripts/clean-next.mjs && node ./node_modules/next/dist/bin/next dev -p 3000",
    "dev:fresh": "npm run dev:clean",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node server.js",
    "start:next": "node ./node_modules/next/dist/bin/next start",
    "backend": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 8080",
    "dev:all": "npm run clean-ports && concurrently \"npm run backend\" \"npm run dev\"",
    "clean-ports": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ports = @(8080,3000); foreach ($p in $ports) { Get-NetTCPConnection -LocalPort $p -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }\"",
    "test:gpr-code": "tsx lib/gprCodeSort.selftest.ts"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "html2canvas": "^1.4.1",
    "iconv-lite": "^0.7.2",
    "is-number": "^7.0.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "next": "^15.0.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
