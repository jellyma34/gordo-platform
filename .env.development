# Локальный `next dev`: FastAPI на том же хосте, что в `start.ps1` (по умолчанию порт 8080).
# Если порт занят, `start.ps1` может выбрать 8081 — тогда выставьте тот же URL здесь или в `.env.local`.
# Удалённый API только при необходимости: задайте URL в `.env.local` (перекрывает этот файл).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
