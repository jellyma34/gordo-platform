# `next dev` (NODE_ENV=development): API по умолчанию — локальный uvicorn.
#
# ВАЖНО: Next.js переопределяет этот файл значениями из `.env.local`.
# Если в Network всё ещё https://gordo-platform-*.railway.app — откройте `.env.local`
# и задайте: NEXT_PUBLIC_API_URL=http://127.0.0.1:8080 , либо удалите `.env.local`.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080
