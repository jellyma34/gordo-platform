# Локальный `next dev`: базовый URL FastAPI (без /api в конце). Должен совпадать с портом uvicorn.
# Если переменная не задана, фронт в dev использует http://localhost:8000 (см. lib/apiClient.ts).
# Перекрытие: `.env.local` (не коммитить).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ГПР без PostgreSQL: Next API + localStorage + mock (см. lib/gprStorageMode.ts).
# Для Railway/production не задавать или явно postgres.
NEXT_PUBLIC_GPR_STORAGE=local
